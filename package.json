{
  "name": "semlimites",
  "version": "1.0.0",
  "description": "SemLimites - Plataforma de prestadores de serviços",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "deploy": "node deploy.js",
    "postdeploy": "git add . && git commit -m \"Deploy para GitHub Pages\" && git push"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "fs-extra": "^11.1.0"
  }
}
